#!/bin/sh /etc/rc.common
# OpenWrt procd init script for SNI-Spoofing.
#
# Reads /etc/config/sni-spoof (UCI), regenerates the runtime config.json, and
# runs main.py under procd with automatic respawn. A LuCI "Save & Apply" commits
# the UCI config, which fires the reload trigger below and restarts the relay.
#
#   /etc/init.d/sni-spoof enable    # start on boot
#   /etc/init.d/sni-spoof start
#   logread -e sni-spoof            # watch output
USE_PROCD=1
START=95
STOP=10

PROG_DIR=/opt/sni-spoof
CONF_JSON="$PROG_DIR/config.json"

# Render config.json from UCI. Echoes the 'enabled' flag on stdout so the caller
# can decide whether to actually launch (the JSON itself goes to the file).
gen_config() {
	local enabled listen_host listen_port connect_ip connect_port fake_sni backend
	config_load 'sni-spoof'
	config_get enabled      main enabled      0
	config_get listen_host  main listen_host  '127.0.0.1'
	config_get listen_port  main listen_port  40443
	config_get connect_ip   main connect_ip   '188.114.99.0'
	config_get connect_port main connect_port 443
	config_get fake_sni     main fake_sni     'chatgpt.com'
	config_get backend      main backend      'auto'

	cat > "$CONF_JSON" <<-EOF
	{
	  "LISTEN_HOST": "$listen_host",
	  "LISTEN_PORT": $listen_port,
	  "CONNECT_IP": "$connect_ip",
	  "CONNECT_PORT": $connect_port,
	  "FAKE_SNI": "$fake_sni",
	  "BACKEND": "$backend",
	  "AUTO_SELECT_INTERFACE": true
	}
	EOF

	echo "$enabled"
}

start_service() {
	local enabled
	enabled="$(gen_config)"
	if [ "$enabled" != "1" ]; then
		echo "sni-spoof: disabled (set 'enabled 1' in /etc/config/sni-spoof or toggle it in LuCI)"
		return 0
	fi

	procd_open_instance
	procd_set_param command /usr/bin/python3 "$PROG_DIR/main.py"
	procd_set_param respawn 3600 5 5      # restart if it dies (threshold, timeout, retries)
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param pidfile /var/run/sni-spoof.pid
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger 'sni-spoof'
}

reload_service() {
	stop
	start
}
